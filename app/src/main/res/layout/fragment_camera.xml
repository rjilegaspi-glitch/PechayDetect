<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Leaf frame guide overlay -->
    <View
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:background="@drawable/camera_frame_overlay"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="60dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/camera_hint"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:background="#88000000"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Bottom controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="40dp"
        android:paddingHorizontal="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Gallery button -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_gallery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_gallery"
            android:contentDescription="@string/select_from_gallery"
            app:backgroundTint="@color/white"
            app:tint="@color/primary_green"
            app:fabSize="mini"
            android:layout_marginEnd="32dp" />

        <!-- Shutter button -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_capture"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_camera_shutter"
            android:contentDescription="@string/capture_photo"
            app:backgroundTint="@color/white"
            app:tint="@color/primary_green"
            app:fabSize="normal" />

        <!-- Flip camera button -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_flip_camera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_flip_camera"
            android:contentDescription="@string/flip_camera"
            app:backgroundTint="@color/white"
            app:tint="@color/primary_green"
            app:fabSize="mini"
            android:layout_marginStart="32dp" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
